pkgname=monody-tools
pkgver=1.0
pkgrel=2
pkgdesc="Custom tools for Monody Linux (Welcome, Users, Updater)"
arch=('x86_64')
url="https://github.com/n0va-bot/monody"
license=('ISC')
depends=('gtk3' 'vte3' 'polkit' 'accountsservice')
makedepends=('vala')

source=("monody-welcome.vala"
        "monody-updater.vala"
        "monody-users.vala"
        "monody-welcome.desktop"
        "monody-users.desktop"
        "monody-updater.desktop")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

build() {
  valac --pkg gtk+-3.0 --pkg vte-2.91 monody-welcome.vala -o monody-welcome
  valac --pkg gtk+-3.0 --pkg vte-2.91 monody-updater.vala -o monody-updater
  valac --pkg gtk+-3.0 --pkg posix monody-users.vala -o monody-users
}

package() {
  install -Dm755 monody-welcome "$pkgdir/usr/bin/monody-welcome"
  install -Dm755 monody-updater "$pkgdir/usr/bin/monody-updater"
  install -Dm755 monody-users "$pkgdir/usr/bin/monody-users"
  
  install -Dm644 monody-welcome.desktop "$pkgdir/usr/share/applications/monody-welcome.desktop"
  install -Dm644 monody-users.desktop "$pkgdir/usr/share/applications/monody-users.desktop"
  install -Dm644 monody-updater.desktop "$pkgdir/usr/share/applications/monody-updater.desktop"
}
