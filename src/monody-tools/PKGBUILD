pkgname=monody-tools
pkgver=1.1.2
pkgrel=2
pkgdesc="Custom tools for Monody Linux"
arch=('x86_64')
url="https://github.com/n0va-bot/monody"
license=('ISC')
depends=('gtk3' 'vte3' 'polkit' 'accountsservice')
makedepends=('vala' 'meson' 'ninja')

source=("monody-welcome.vala"
        "monody-updater.vala"
        "monody-users.vala"
        "monody-welcome.desktop"
        "monody-users.desktop"
        "monody-updater.desktop"
        "meson.build")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

build() {
  arch-meson . build
  meson compile -C build
}

package() {
  DESTDIR="$pkgdir" meson install -C build

  install -Dm644 monody-welcome.desktop "$pkgdir/usr/share/applications/monody-welcome.desktop"
  install -Dm644 monody-users.desktop "$pkgdir/usr/share/applications/monody-users.desktop"
  install -Dm644 monody-updater.desktop "$pkgdir/usr/share/applications/monody-updater.desktop"
}
