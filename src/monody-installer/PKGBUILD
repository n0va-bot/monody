pkgname=monody-installer
pkgver=1.0.0
pkgrel=1
pkgdesc="Installer for Monody Linux"
arch=('x86_64')
url="https://github.com/n0va-bot/monody"
license=('ISC')
depends=('gtk3' 'timezonemap' 'vte3' 'gparted' 'btrfs-progs' 'cryptsetup')
makedepends=('vala' 'meson' 'ninja')

source=("monody-installer.vala"
        "config.vala"
        "engine.vala"
        "utils.vala"
        "disk.vala"
        "keymap.vala"
        "install_type.vala"
        "mountpoint.vala"
        "progress.vala"
        "summary.vala"
        "timezone.vala"
        "user.vala"
        "welcome.vala"
        "monody-installer.desktop"
        "org.monody.installer.policy"
        "timezonemap.vapi"
        "meson.build")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

build() {
  arch-meson . build
  meson compile -C build
}

package() {
  DESTDIR="$pkgdir" meson install -C build
  install -Dm644 monody-installer.desktop "$pkgdir/usr/share/applications/monody-installer.desktop"
  install -Dm644 org.monody.installer.policy "$pkgdir/usr/share/polkit-1/actions/org.monody.installer.policy"
}
