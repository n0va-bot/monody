pkgname=monody-file-search-provider
pkgver=1.1.1
pkgrel=2
pkgdesc="File search provider for Xfdashboard (and other)"
arch=('x86_64')
url="https://github.com/n0va-bot/monody"
license=('ISC')
depends=('glib2' 'gtk3' 'xfconf')
makedepends=('vala' 'meson' 'ninja')

source=("monody-file-search-provider.vala"
        "monody-file-search-settings.vala"
        "monody-file-search-provider.desktop"
        "monody-file-search-settings.desktop"
        "monody-file-search-provider.ini"
        "org.monody.FileSearch.service"
        "xfconf.vapi"
        "meson.build")
sha256sums=('SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP'
            'SKIP')

build() {
  arch-meson . build
  meson compile -C build
}

package() {
  DESTDIR="$pkgdir" meson install -C build

  install -Dm644 monody-file-search-provider.desktop \
    "$pkgdir/usr/share/applications/monody-file-search-provider.desktop"

  install -Dm644 monody-file-search-settings.desktop \
    "$pkgdir/usr/share/applications/monody-file-search-settings.desktop"

  install -Dm644 monody-file-search-provider.ini \
    "$pkgdir/usr/share/gnome-shell/search-providers/monody-file-search-provider.ini"

  install -Dm644 org.monody.FileSearch.service \
    "$pkgdir/usr/share/dbus-1/services/org.monody.FileSearch.service"
}
